# =============================================================================
# .env.example — copy this file to .env and fill in your values
# NEVER commit .env to git (it is gitignored)
# =============================================================================

# ── Local LLM ─────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
DEFAULT_MODEL=gemma4:e2b

# ── Search ────────────────────────────────────────────────────────────────────
# SearXNG (self-hosted, privacy-first) — start with:
#   docker compose -f docker-compose.searxng.yml up -d
# Falls back to DuckDuckGo automatically if unreachable.
SEARXNG_URL=http://localhost:8889

# ── Telegram Bot (optional — for Orchestrator task notifications) ─────────────
# Quick setup from chat: type /telegram setup
# Manual setup:
#   1. Telegram -> @BotFather -> /newbot -> copy token
#   2. Send any message to your bot
#   3. python -m utils.telegram --get-chat-id
#   4. python -m utils.telegram --test
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# TELEGRAM_CHAT_ID=123456789

# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=7860
APP_HOST=127.0.0.1
LOG_LEVEL=INFO

# ── Timezone (IMPORTANT for Orchestrator cron schedules) ──────────────────────
# Without this, all cron times are interpreted as UTC.
# Find your zone: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Examples: UTC, Europe/Warsaw, America/New_York, Asia/Tokyo, Australia/Sydney
TZ=UTC

# ── Optional authentication (leave blank = no auth, open localhost access) ────
# Uncomment and set to protect the UI with a username/password.
# Useful when running on a shared machine or exposing via ngrok/Tailscale.
# APP_USERNAME=admin
# APP_PASSWORD=changeme

# ── Future integrations (add as needed, never hardcode in source) ─────────────
# BRAVE_SEARCH_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
